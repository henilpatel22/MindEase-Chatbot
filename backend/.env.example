# ─────────────────────────────────────────────
#  MindEase Backend — Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB (local instance — no Atlas required)
MONGODB_URI=mongodb://localhost:27017/mindease

# JWT Secrets (change these to long random strings in production)
JWT_ACCESS_SECRET=mindease_access_secret_change_me_in_production
JWT_REFRESH_SECRET=mindease_refresh_secret_change_me_in_production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AI Service URL
AI_SERVICE_URL=http://localhost:5001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
